# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
/opd-unity/.utmp/
/opd-unity/[Ll]ibrary/
/opd-unity/[Tt]emp/
/opd-unity/[Oo]bj/
/opd-unity/[Bb]uild/
/opd-unity/[Bb]uilds/
/opd-unity/[Ll]ogs/
/opd-unity/[Uu]ser[Ss]ettings/
*.log

# By default unity supports Blender asset imports, *.blend1 blender files do not need to be commited to version control.
/opd-unity/*.blend1
/opd-unity/*.blend1.meta

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
/opd-unity/[Mm]emoryCaptures/

# Recordings can get excessive in size
/opd-unity/[Rr]ecordings/

# Uncomment this line if you wish to ignore the asset store tools plugin
# /[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
/opd-unity/[Aa]ssets/Plugins/Editor/JetBrains*
# Jetbrains Rider personal-layer settings
/opd-unity/*.DotSettings.user

# Visual Studio cache directory
/opd-unity/.vs/

# Gradle cache directory
/opd-unity/.gradle/

# Autogenerated VS/MD/Consulo solution and project files
/opd-unity/ExportedObj/
/opd-unity/.consulo/
/opd-unity/*.csproj
/opd-unity/*.unityproj
/opd-unity/*.sln
/opd-unity/*.suo
/opd-unity/*.tmp
/opd-unity/*.user
/opd-unity/*.userprefs
/opd-unity/*.pidb
/opd-unity/*.booproj
/opd-unity/*.svd
/opd-unity/*.pdb
/opd-unity/*.mdb
/opd-unity/*.opendb
/opd-unity/*.VC.db

# Unity3D generated meta files
/opd-unity/*.pidb.meta
/opd-unity/*.pdb.meta
/opd-unity/*.mdb.meta

# Unity3D generated file on crash reports
/opd-unity/sysinfo.txt

# Mono auto generated files
/opd-unity/mono_crash.*

# Builds
/opd-unity/*.apk
/opd-unity/*.aab
/opd-unity/*.unitypackage
/opd-unity/*.unitypackage.meta
/opd-unity/*.app

# Crashlytics generated file
/opd-unity/crashlytics-build.properties

# TestRunner generated files
/opd-unity/InitTestScene*.unity*

# Addressables default ignores, before user customizations
/opd-unity/ServerData
/opd-unity/[Aa]ssets/StreamingAssets/aa*
/opd-unity/[Aa]ssets/AddressableAssetsData/link.xml*
/opd-unity/[Aa]ssets/Addressables_Temp*
# By default, Addressables content builds will generate addressables_content_state.bin
# files in platform-specific subfolders, for example:
# /Assets/AddressableAssetsData/OSX/addressables_content_state.bin
/opd-unity/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting auto-generated files
/opd-unity/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/opd-unity/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/opd-unity/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/opd-unity/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# Auto-generated scenes by play mode tests
/opd-unity/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

/opd-unity/2D
/opd-unity/.vscode
